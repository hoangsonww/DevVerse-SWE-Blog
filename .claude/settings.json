{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status --short)",
      "Bash(git diff --name-only *)",
      "Bash(git diff --stat *)",
      "Bash(env JEST_USE_WATCHMAN=0 npm test -- --runInBand --watchman=false)",
      "Bash(env JEST_USE_WATCHMAN=0 npm run coverage -- --runInBand --watchman=false)",
      "Bash(npx tsc --noEmit --pretty false)",
      "Bash(python3 .claude/scripts/check_content_contract.py)"
    ],
    "ask": [
      "Bash(npm run build)",
      "Bash(npm run format)",
      "Bash(npm run lint)",
      "Bash(npm run vectorize:articles)",
      "Bash(node scripts/vectorize_articles.mjs *)",
      "Bash(npm install *)",
      "Bash(git push *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "Write(./.env)",
      "Write(./.env.*)",
      "Read(./.claude/settings.local.json)",
      "Edit(./.claude/settings.local.json)",
      "Write(./.claude/settings.local.json)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/scripts/session_start.py\""
          }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/scripts/session_start.py\""
          }
        ]
      },
      {
        "matcher": "clear",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/scripts/session_start.py\""
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/scripts/session_start.py\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/scripts/pretool_guard.py\""
          }
        ]
      }
    ]
  }
}
